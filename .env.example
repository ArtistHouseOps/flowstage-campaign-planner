# Copy to .env.local and fill in real values. .env* is gitignored.

# Flowstage API key — server-side only, never expose to the browser.
FLOWSTAGE_API_KEY=

# Upstash Redis (via Vercel KV / Upstash marketplace integration).
# Vercel's Upstash integration injects these two names automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Local dev only: skip Upstash and use an in-memory KV. Lost on process restart.
# Leave unset in production.
KV_MOCK=

# Inngest. INNGEST_DEV=1 tells the SDK to use the local Inngest dev server
# (https://www.inngest.com/docs/local-development) instead of cloud, and lets
# you set a dummy event/signing key for dev. In production set the real keys
# from the Inngest dashboard and leave INNGEST_DEV unset.
INNGEST_DEV=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Optional: public base URL of this deployment.
NEXT_PUBLIC_APP_URL=
